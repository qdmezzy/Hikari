# Supabase — same project as the web app. The anon key is public; it's safe
# to ship in the app bundle (RLS protects the data). Without these, the app
# runs in browse-only mode (AniList catalog still works, no auth/tracking).
EXPO_PUBLIC_SUPABASE_URL=your-project-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — Discord invite link used by the Discord promo card.
EXPO_PUBLIC_DISCORD_INVITE_URL=
